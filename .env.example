# Copy this file to .env and fill in your values.
# .env is never committed to git (add it to .gitignore).

# ── LLM Backend ──────────────────────────────────────────────────────────────
# "anthropic" (default, cloud) or "openai" (any OpenAI-compatible server)
LLM_PROVIDER=anthropic

# ── Anthropic (cloud) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI-compatible (local: Ollama / llama.cpp / LM Studio / vLLM) ─────────
# OPENAI_BASE_URL=http://localhost:11434/v1   # Ollama default
# OPENAI_BASE_URL=http://localhost:8080/v1    # llama.cpp default
# OPENAI_BASE_URL=http://localhost:1234/v1    # LM Studio default
# OPENAI_API_KEY=ollama                       # any non-empty string for local servers
# LLM_MODEL=llama3.2                          # model name your server expects
